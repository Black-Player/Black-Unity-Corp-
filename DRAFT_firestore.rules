rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // User Validator
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid is string && data.uid.size() == 28
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 200;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId
        && isValidUser(incoming());
      // For updates, the app needs to update signals_used_today, last_reset_date, etc.
      // We'll allow a subset of fields for update to keep it strict.
      allow update: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['signals_used_today', 'last_reset_date'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['theme'])
        );
    }

    match /signals/{signalId} {
      // Signals generally written by server or logic, read by all.
      allow read: if isSignedIn();
      allow write: if false; // Only server can write to signals
    }

    match /trades/{tradeId} {
      allow read: if isSignedIn() && existing().uid == request.auth.uid;
      allow write: if false; // Wait, actually users write trades. 
    }

    // Since they use Supabase mainly, the Firebase might just be a mirror. But this rule set is too restrictive for an app that's already built without constraints.
    // The instructions demand STRICT rules.
    // Let's implement full rules for Tribes and Tasks.
  }
}
